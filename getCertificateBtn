document.getElementById('getCertificateBtn').onclick = () => {
    const userName = localStorage.getItem('userName') || "Beloved Servant";
    const score = currentScore || 0;
    const total = QUESTIONS.length;
    const points = currentPoints || 0;
    const level = getLevel(points).name;
    const date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    
    const certificateHTML = `
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <title>Good Way - Certificate of Completion</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body {
                    font-family: 'Georgia', 'Times New Roman', serif;
                    background: linear-gradient(135deg, #1a1035 0%, #2d1b4e 100%);
                    min-height: 100vh;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    padding: 40px;
                }
                .certificate {
                    max-width: 800px;
                    width: 100%;
                    background: white;
                    border: 20px solid #ffd700;
                    border-radius: 20px;
                    padding: 50px 40px;
                    text-align: center;
                    box-shadow: 0 30px 50px rgba(0,0,0,0.3);
                    position: relative;
                }
                .certificate::before {
                    content: "🕊️";
                    position: absolute;
                    top: -30px;
                    left: 50%;
                    transform: translateX(-50%);
                    font-size: 60px;
                    background: white;
                    padding: 0 20px;
                }
                .certificate h1 {
                    font-size: 42px;
                    color: #2d1b4e;
                    margin-bottom: 20px;
                    font-family: 'Georgia', serif;
                }
                .certificate .subtitle {
                    color: #ffd700;
                    font-size: 18px;
                    letter-spacing: 2px;
                    margin-bottom: 30px;
                }
                .certificate .presented {
                    font-size: 16px;
                    color: #666;
                    margin: 20px 0;
                }
                .certificate .name {
                    font-size: 48px;
                    font-weight: bold;
                    color: #ffd700;
                    text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
                    margin: 20px 0;
                    border-bottom: 2px solid #ffd700;
                    display: inline-block;
                    padding: 0 30px 10px;
                }
                .certificate .achievement {
                    font-size: 20px;
                    margin: 25px 0;
                    line-height: 1.6;
                    color: #333;
                }
                .certificate .score-box {
                    background: linear-gradient(135deg, #f8f4ff, #e9dcf5);
                    padding: 20px;
                    border-radius: 15px;
                    margin: 25px 0;
                }
                .certificate .score {
                    font-size: 36px;
                    font-weight: bold;
                    color: #5a3e8c;
                }
                .certificate .level {
                    font-size: 24px;
                    color: #ffd700;
                    font-weight: bold;
                    margin: 10px 0;
                }
                .certificate .date {
                    margin: 30px 0 20px;
                    color: #666;
                    font-size: 14px;
                }
                .certificate .footer {
                    margin-top: 30px;
                    padding-top: 20px;
                    border-top: 1px solid #eee;
                    font-size: 12px;
                    color: #999;
                }
                .certificate .signature {
                    margin-top: 20px;
                    display: flex;
                    justify-content: space-between;
                    padding: 0 20px;
                }
                .certificate .sign-line {
                    text-align: center;
                }
                .certificate .sign-line hr {
                    width: 200px;
                    margin: 5px 0;
                }
                @media print {
                    body { background: white; padding: 0; }
                    .certificate { box-shadow: none; border: 15px solid #ffd700; }
                    button { display: none; }
                }
                button {
                    background: linear-gradient(135deg, #5a3e8c, #ffd700);
                    color: white;
                    border: none;
                    padding: 12px 30px;
                    font-size: 16px;
                    border-radius: 40px;
                    cursor: pointer;
                    margin-top: 20px;
                    font-weight: bold;
                }
                button:hover {
                    transform: scale(1.02);
                }
            </style>
        </head>
        <body>
            <div class="certificate">
                <h1>🎓 Certificate of Completion</h1>
                <div class="subtitle">GOOD WAY - MARK'S GOSPEL QUIZ</div>
                <div class="presented">This certificate is proudly presented to</div>
                <div class="name">${userName}</div>
                <div class="achievement">For successfully completing the<br><strong>Mark's Gospel Quiz</strong></div>
                <div class="score-box">
                    <div>Score: <span class="score">${score}/${total}</span></div>
                    <div>Points Earned: <strong>${points} ⭐</strong></div>
                    <div class="level">🏆 ${level}</div>
                </div>
                <div class="date">Awarded on this day: ${date}</div>
                <div class="signature">
                    <div class="sign-line">
                        <hr>
                        <div>Mr Addis Abebayehu</div>
                        <div>Developer</div>
                    </div>
                    <div class="sign-line">
                        <hr>
                        <div>Good Way App</div>
                        <div>agoodperception@gmail.com</div>
                    </div>
                </div>
                <div class="footer">
                    "The beginning of the gospel of Jesus Christ, the Son of God." - Mark 1:1
                </div>
                <button onclick="window.print()">🖨️ Print / Save as PDF</button>
                <button onclick="window.close()" style="background:#666; margin-left:10px;">✖ Close</button>
            </div>
            <script>
                // Auto-trigger print dialog for easy saving
                setTimeout(() => { if(confirm('Save this certificate as PDF? Click OK to print/save.')) window.print(); }, 500);
            </script>
        </body>
        </html>
    `;
    
    const certWindow = window.open('', '_blank');
    certWindow.document.write(certificateHTML);
    certWindow.document.close();
};
